# ── LLM Provider ──────────────────────────
# Uncomment and set the API key for your provider
# OPENROUTER_API_KEY=sk-or-v1-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
# CEREBRAS_API_KEY=xxx

# ── Chat Channel ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx
# LINE_CHANNEL_SECRET=xxx
# LINE_CHANNEL_ACCESS_TOKEN=xxx

# ── Web Search (optional) ────────────────
# BRAVE_SEARCH_API_KEY=BSA...

# Skill helpers (persistent ~/.picoclaw/.env or docker/data/.env)
# CPA_API_KEY=your-cpa-key
# CPA_API_BASE=https://your-openai-compatible-endpoint.example/v1
# CPA_STT_MODEL=google/gemini-3-flash-preview
# EXA_API_KEY=exa_xxx
# EXA_API_BASE=https://api.exa.ai
# HF_TOKEN=hf_xxx

# ── Timezone ──────────────────────────────
TZ=Asia/Tokyo


